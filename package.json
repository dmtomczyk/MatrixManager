{
  "name": "matrixmanager",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "db:reset": "./.venv/bin/python scripts/reset_db.py",
    "db:seed": "./.venv/bin/python scripts/seed_sample_data.py",
    "dev:api": "./.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
    "dev:api:ui": "MATRIX_UI_DEV_URL=http://127.0.0.1:4173 ./.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
    "dev:ui": "vite --config frontend/ui/vite.config.mjs",
    "dev": "bash -lc 'trap \"kill 0\" EXIT; MATRIX_UI_DEV_URL=http://127.0.0.1:4173 ./.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload & ./node_modules/.bin/vite --config frontend/ui/vite.config.mjs & wait'",
    "dev:stop": "bash -lc 'pkill -f \"vite --config frontend/ui/vite.config.mjs\" || true; pkill -f \"uvicorn app.main:app\" || true; fuser -k 4173/tcp 2>/dev/null || true; fuser -k 8000/tcp 2>/dev/null || true'",
    "lint:ui": "eslint frontend/ui/src --ext .ts,.tsx,.js,.jsx",
    "typecheck:ui": "tsc --project frontend/ui/tsconfig.json",
    "build:ui": "vite build --config frontend/ui/vite.config.mjs"
  },
  "dependencies": {
    "@xyflow/react": "^12.8.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.53.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^5.4.19"
  }
}
